#!/bin/bash

daemon::remove() {
  local name=$1

  if [ "$name" = "" ]; then
    log::error "daemon service and command are required"
    exit 1
  fi

  local service_name=$(daemon_get_service_name $name)
  local service_path=$(daemon_service::get_path $name)
  local script_path=$DAEMON_SERVICE_SCRIPT_DIR/$name
  local has_service_file="false"
  local has_script_file="false"
  if [ -f "$service_path" ]; then
    has_service_file="true"
  fi
  if [ -f "$script_path" ]; then
    has_script_file="true"
  fi

  if [ "$has_service_file" = "false" ] && [ "$has_script_file" = "false" ]; then
    log::error "daemon service(${name}) not found"
    exit 1
  fi

  if [ "$(os::is_macos)" = "true" ]; then
    # stop before removing files, otherwise daemon::stop may fail on existence checks
    if [ "$has_service_file" = "true" ]; then
      daemon::stop $name
    else
      # cleanup loaded job even when plist file is already missing
      sudo launchctl remove $service_name >>/dev/null 2>&1
    fi

    sudo launchctl disable system/$service_name >>/dev/null 2>&1
    sudo rm -f "$service_path"
    sudo rm -f "$script_path"
    log::success "daemon serice ${name} removed"
    return
  fi

  # stop before remove for linux too
  if [ "$has_service_file" = "true" ]; then
    if [ "$(os::has_command systemctl)" = "true" ]; then
      if [ "$(os::is_docker)" != "true" ]; then
        sudo systemctl stop $service_name
      fi
    elif [ "$(os::has_command service)" = "true" ]; then
      sudo service $name stop
    fi
  fi

  # remove service/script files
  sudo rm -f "$service_path"
  sudo rm -f "$script_path"

  # systemd
  if [ "$(os::has_command systemctl)" = "true" ]; then
    if [ "$(os::is_docker)" != "true" ]; then
      sudo systemctl daemon-reload
      return $?
    fi
  fi

  # sysv
  if [ "$(os::has_command service)" = "true" ]; then
    return 0
  fi

  log::success "daemon serice ${name} removed"
}

export -f daemon::remove
