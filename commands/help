#!/bin/bash

help() {
  echo "zdaemon - manage background services"
  echo ""
  echo "Usage:"
  echo "  zdaemon <action> [args]"
  echo ""
  echo "Actions:"
  echo "  create [name] [command...]    Create service, start immediately, and enable startup"
  echo "  remove [name]                 Remove service files and stop service"
  echo "  start [name]                  Start service"
  echo "  stop [name]                   Stop service"
  echo "  restart [name]                Restart service"
  echo "  reload [name]                 Reload service (or restart when reload is unsupported)"
  echo "  status [name]                 Show service status"
  echo "  logs [name] [-f|--follow]     Show service logs"
  echo "  list                          List available services"
  echo "  enable [name]                 Enable service at system startup"
  echo "  disable [name]                Disable service at system startup"
  echo "  script <command> [name]       Manage service script"
  echo ""
  echo "Script subcommands:"
  echo "  script edit [name]            Edit service script and auto reload service"
  echo "  script view [name]            Print service script content"
  echo "  script path [name]            Print service script file path"
  echo ""
  echo "Examples:"
  echo "  zdaemon create test-date \"date && sleep 10\""
  echo "  zdaemon script edit test-date"
  echo "  zdaemon script view test-date"
  echo "  zdaemon script path test-date"
  echo "  zdaemon logs test-date --follow"
}

help